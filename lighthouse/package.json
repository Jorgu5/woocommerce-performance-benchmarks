{
  "name": "woocommerce-performance-benchmarks-lighthouse",
  "version": "1.0.0",
  "description": "Puppeteer + Lighthouse scripts for WooCommerce Store API vs Classic checkout benchmarks",
  "private": true,
  "type": "module",
  "scripts": {
    "audit:cached": "node audit-cached.mjs all",
    "audit:cold": "node audit-with-cart.mjs all",
